{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.liftandmeasure.com"
        }
      ],
      "destination": "https://liftandmeasure.com/:path*",
      "statusCode": 301
    }
  ]
}
