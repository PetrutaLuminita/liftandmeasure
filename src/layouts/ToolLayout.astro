---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../data/tools.js';

const {
  title,
  description,
  slug,
  summary,
  faq = [],
} = Astro.props;

const tool = getTool(slug);
const path = `/${slug}`;
const canonicalURL = new URL(path, Astro.site);

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: String(Astro.site) },
    {
      '@type': 'ListItem',
      position: 2,
      name: tool.category,
      item: `${String(Astro.site)}#${tool.category.toLowerCase().replace(/\s+/g, '-')}`,
    },
    { '@type': 'ListItem', position: 3, name: tool.name, item: String(canonicalURL) },
  ],
};

const softwareAppSchema = {
  '@type': 'SoftwareApplication',
  name: tool.name,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any (web browser)',
  url: String(canonicalURL),
  description: description,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

const faqSchema = faq.length
  ? {
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;

const schema = [breadcrumbSchema, softwareAppSchema, ...(faqSchema ? [faqSchema] : [])];

const categoryAnchor = tool.category.toLowerCase().replace(/\s+/g, '-');
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep">&gt;</span>
    <a href={`/#${categoryAnchor}`}>{tool.category}</a>
    <span class="sep">&gt;</span>
    <span aria-current="page">{tool.name}</span>
  </nav>

  <h1>{tool.name}</h1>
  <p class="tool-summary">{summary}</p>

  <AdSlot position="tool-top" />

  <slot name="tool" />

  <AdSlot position="tool-result" />

  <slot name="how-it-works" />

  {faq.length > 0 && (
    <section aria-label="Frequently asked questions">
      <h2>Frequently Asked Questions</h2>
      {faq.map((item) => (
        <div class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </div>
      ))}
    </section>
  )}

  <AdSlot position="tool-bottom" />

  <RelatedTools current={slug} count={3} />
</BaseLayout>
