# Copy this file to .env to use it locally. Leave PUBLIC_SHOW_AD_PLACEHOLDERS
# unset (or false) in production so the site does not show empty bordered
# "Advertisement" boxes before real AdSense code is added.
#
# Set it to true locally when you want to see where the ad slots sit on the
# page during development or design review.
PUBLIC_SHOW_AD_PLACEHOLDERS=false
